          "expr": "outline_ws_rust_uplink_mode_downgrade_remaining_seconds{job=~\"$job\",instance=~\"$instance\",group=~\"$group\"}",
          "legendFormat": "{{transport}} {{uplink}}",
          "refId": "A"
        }
      ],
      "title": "Mode-Downgrade Window Remaining",
      "type": "timeseries"
    },
