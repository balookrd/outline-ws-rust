{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      },
      {
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROMETHEUS}"
        },
        "enable": true,
        "expr": "changes(outline_ws_rust_global_active_uplink_info{job=~\"$job\",instance=~\"$instance\"}[1m]) > 0",
        "iconColor": "yellow",
        "name": "Active uplink switch",
        "step": "1m",
        "tagKeys": "instance,uplink",
        "titleFormat": "uplink switch",
        "useValueForTime": false
      },
      {
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROMETHEUS}"
        },
        "enable": true,
        "expr": "increase(outline_ws_rust_uplink_failovers_total{job=~\"$job\",instance=~\"$instance\"}[1m]) > 0",
        "iconColor": "red",
        "name": "Failover",
        "step": "1m",
        "tagKeys": "instance,from_uplink,to_uplink,transport",
        "titleFormat": "failover",
        "useValueForTime": false
      }
    ]
  },
  "description": "Diagnostic dashboard for situational hangs (sites stop loading until uplink is switched). Covers three hypotheses: warm-standby pool with stale connections, H3/QUIC poll deadlocks, and stuck mode-downgrade state. Cross-references TUN TCP stall signals.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0},
      "id": 1,
      "panels": [],
      "title": "Hang Signals — Top Line",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "description": "TUN TCP flows stalled on zero-window (peer not draining). Should be ~0; sustained >0 = client-side back-pressure stalling sites.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": 0},
              {"color": "yellow", "value": 1},
              {"color": "red", "value": 5}
            ]
          },
          "unit": "none"
        }
      },
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 1},
      "id": 2,
      "options": {
        "colorMode": "value", "graphMode": "area", "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "auto"
      },
      "targets": [
        {
          "expr": "sum(outline_ws_rust_tun_tcp_zero_window_flows{job=~\"$job\",instance=~\"$instance\"})",
          "legendFormat": "zero-window flows",
          "refId": "A"
        }
      ],
      "title": "TUN TCP Zero-Window Flows",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "description": "TUN TCP flows with pending server data but no recent ACK progress. Direct symptom of a stuck transport on this uplink.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": 0},
              {"color": "yellow", "value": 1},
              {"color": "red", "value": 5}
            ]
          },
          "unit": "none"
        }
      },
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 1},
      "id": 3,
      "options": {
        "colorMode": "value", "graphMode": "area", "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "auto"
      },
      "targets": [
        {
          "expr": "sum(outline_ws_rust_tun_tcp_ack_progress_stall_flows{job=~\"$job\",instance=~\"$instance\"})",
          "legendFormat": "ack-stalled flows",
          "refId": "A"
        }
      ],
      "title": "TUN TCP ACK-Progress Stalled",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "description": "Uplinks with active_wire_index > 0 = sticky on a fallback wire. If this stays >0 for long, the primary wire of that uplink is degraded but no failover happened.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": 0},
              {"color": "yellow", "value": 1}
            ]
          },
          "unit": "none"
        }
      },
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 1},
      "id": 4,
      "options": {
        "colorMode": "value", "graphMode": "area", "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "auto"
      },
      "targets": [
        {
          "expr": "count(outline_ws_rust_uplink_active_wire_index{job=~\"$job\",instance=~\"$instance\"} > 0)",
          "legendFormat": "uplinks on fallback wire",
          "refId": "A"
        }
      ],
      "title": "Uplinks on Fallback Wire",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "description": "Effective health gauge — 0 means uplink is currently NOT delivering traffic (probe failed AND no fallback rescue). Stuck-at-0 with no failover = main symptom of state-machine lock.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": 0},
              {"color": "green", "value": 1}
            ]
          },
          "unit": "none"
        }
      },
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 1},
      "id": 5,
      "options": {
        "colorMode": "value", "graphMode": "area", "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "auto"
      },
      "targets": [
        {
          "expr": "min(outline_ws_rust_uplink_health_effective{job=~\"$job\",instance=~\"$instance\"})",
          "legendFormat": "min effective health",
          "refId": "A"
        }
      ],
      "title": "Worst Effective Uplink Health",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 5},
      "id": 10,
      "panels": [],
      "title": "Hypothesis 1 — Standby Pool with Stale Connections",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "description": "Warm-standby ready connections per uplink/transport. A drop to 0 right before a hang = pool starved (refills failing or all entries reused as zombies). A spike up right after a switch = pool was reset.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"drawStyle": "line", "fillOpacity": 10, "lineWidth": 1, "showPoints": "never", "spanNulls": false},
          "unit": "none"
        }
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 6},
      "id": 11,
      "options": {
        "legend": {"calcs": ["min", "max", "lastNotNull"], "displayMode": "table", "placement": "bottom", "showLegend": true},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "targets": [
        {
          "expr": "outline_ws_rust_uplink_standby_ready{job=~\"$job\",instance=~\"$instance\",group=~\"$group\"}",
          "legendFormat": "{{transport}} {{group}}/{{uplink}}",
          "refId": "A"
        }
      ],
      "title": "Standby Ready (per uplink/transport)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "description": "Acquire outcomes — 'hit' = pool gave a connection, 'miss' = had to dial fresh. A burst of misses with simultaneous high ready count would mean the pool gave back zombies that immediately failed.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"drawStyle": "line", "fillOpacity": 10, "lineWidth": 1, "showPoints": "never", "stacking": {"mode": "normal"}},
          "unit": "ops"
        }
      },
      "gridPos": {"h": 8, "w": 6, "x": 12, "y": 6},
      "id": 12,
      "options": {
        "legend": {"calcs": ["max"], "displayMode": "list", "placement": "bottom", "showLegend": true},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "targets": [
        {
          "expr": "sum by (transport, outcome) (rate(outline_ws_rust_warm_standby_acquire_total{job=~\"$job\",instance=~\"$instance\",group=~\"$group\"}[$__rate_interval]))",
          "legendFormat": "{{transport}} {{outcome}}",
          "refId": "A"
        }
      ],
      "title": "Warm-Standby Acquire (by outcome)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "description": "Refill error rate. Sustained errors mean the pool can't be replenished — eventually all 'ready' slots are stale and acquire-by-pool returns zombies that hang the session.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"drawStyle": "line", "fillOpacity": 10, "lineWidth": 1, "showPoints": "never"},
          "unit": "ops"
        }
      },
      "gridPos": {"h": 8, "w": 6, "x": 18, "y": 6},
      "id": 13,
      "options": {
        "legend": {"calcs": ["max"], "displayMode": "list", "placement": "bottom", "showLegend": true},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "targets": [
        {
          "expr": "sum by (transport, result) (rate(outline_ws_rust_warm_standby_refill_total{job=~\"$job\",instance=~\"$instance\",group=~\"$group\"}[$__rate_interval]))",
          "legendFormat": "{{transport}} {{result}}",
          "refId": "A"
        }
      ],
      "title": "Warm-Standby Refill (by result)",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 14},
      "id": 20,
      "panels": [],
      "title": "Hypothesis 2 — H3/QUIC poll deadlock and transport stalls",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "description": "Active upstream transports per protocol. If H3/XHTTP count plateaus at the cap while sessions also pile up, transports are not closing — classic poll_write/poll_shutdown deadlock signature.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"drawStyle": "line", "fillOpacity": 10, "lineWidth": 1, "showPoints": "never"},
          "unit": "none"
        }
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 15},
      "id": 21,
      "options": {
        "legend": {"calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "targets": [
        {
          "expr": "outline_ws_rust_upstream_transports_active{job=~\"$job\",instance=~\"$instance\"}",
          "legendFormat": "{{source}} {{protocol}}",
          "refId": "A"
        },
        {
          "expr": "outline_ws_rust_transport_connects_active{job=~\"$job\",instance=~\"$instance\"}",
          "legendFormat": "connecting {{source}} {{mode}}",
          "refId": "B"
        }
      ],
      "title": "Active Upstream Transports & In-Flight Connects",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "description": "Sessions stuck open. Compare with bytes_total rate — if sessions_active grows but bytes rate drops, sessions are alive but idle = transport hang.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"axisPlacement": "auto", "drawStyle": "line", "fillOpacity": 10, "lineWidth": 1, "showPoints": "never"},
          "unit": "none"
        },
        "overrides": [
          {
            "matcher": {"id": "byRegexp", "options": "bytes/sec.*"},
            "properties": [
              {"id": "unit", "value": "binBps"},
              {"id": "custom.axisPlacement", "value": "right"}
            ]
          }
        ]
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 15},
      "id": 22,
      "options": {
        "legend": {"calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "targets": [
        {
          "expr": "sum by (protocol) (outline_ws_rust_sessions_active{job=~\"$job\",instance=~\"$instance\"})",
          "legendFormat": "sessions {{protocol}}",
          "refId": "A"
        },
        {
          "expr": "sum by (protocol, direction) (rate(outline_ws_rust_bytes_total{job=~\"$job\",instance=~\"$instance\",group=~\"$group\"}[$__rate_interval]))",
          "legendFormat": "bytes/sec {{protocol}} {{direction}}",
          "refId": "B"
        }
      ],
      "title": "Sessions Active vs Throughput (divergence = stall)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "description": "Aggregate inflight server→client bytes and pending bytes (queued, awaiting client window). A flat-top with ack-stall flows >0 means the transport is the bottleneck, not the client.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"drawStyle": "line", "fillOpacity": 10, "lineWidth": 1, "showPoints": "never"},
          "unit": "bytes"
        }
      },
      "gridPos": {"h": 7, "w": 12, "x": 0, "y": 23},
      "id": 23,
      "options": {
        "legend": {"calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "targets": [
        {
          "expr": "sum by (uplink) (outline_ws_rust_tun_tcp_inflight_bytes{job=~\"$job\",instance=~\"$instance\",group=~\"$group\"})",
          "legendFormat": "inflight {{uplink}}",
          "refId": "A"
        },
        {
          "expr": "sum by (uplink) (outline_ws_rust_tun_tcp_pending_server_bytes{job=~\"$job\",instance=~\"$instance\",group=~\"$group\"})",
          "legendFormat": "pending {{uplink}}",
          "refId": "B"
        }
      ],
      "title": "TUN TCP Inflight & Pending Bytes",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "description": "Stalled flows broken down per uplink. The uplink whose value spikes right before user-visible hang is the suspect carrier; if drains to 0 only on switch, that confirms the state was per-uplink.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"drawStyle": "line", "fillOpacity": 10, "lineWidth": 1, "showPoints": "never"},
          "unit": "none"
        }
      },
      "gridPos": {"h": 7, "w": 12, "x": 12, "y": 23},
      "id": 24,
      "options": {
        "legend": {"calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "targets": [
        {
          "expr": "outline_ws_rust_tun_tcp_zero_window_flows{job=~\"$job\",instance=~\"$instance\",group=~\"$group\"}",
          "legendFormat": "zero-win {{uplink}}",
          "refId": "A"
        },
        {
          "expr": "outline_ws_rust_tun_tcp_ack_progress_stall_flows{job=~\"$job\",instance=~\"$instance\",group=~\"$group\"}",
          "legendFormat": "ack-stall {{uplink}}",
          "refId": "B"
        },
        {
          "expr": "outline_ws_rust_tun_tcp_backlog_pressure_flows{job=~\"$job\",instance=~\"$instance\",group=~\"$group\"}",
          "legendFormat": "backlog {{uplink}}",
          "refId": "C"
        }
      ],
      "title": "Stalled Flow Counts (per uplink)",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 30},
      "id": 30,
      "panels": [],
      "title": "Hypothesis 3 — Mode Downgrade & Switching State",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "description": "Probe-confirmed health vs effective (probe-or-fallback-rescue). A wide gap = uplink is rescued only by fallback; if effective drops to 0 too — total outage.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"drawStyle": "line", "fillOpacity": 5, "lineWidth": 2, "showPoints": "never"},
          "unit": "none",
          "min": 0,
          "max": 1
        }
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 31},
      "id": 31,
      "options": {
        "legend": {"calcs": ["lastNotNull"], "displayMode": "table", "placement": "bottom", "showLegend": true},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "targets": [
        {
          "expr": "outline_ws_rust_uplink_health{job=~\"$job\",instance=~\"$instance\",group=~\"$group\"}",
          "legendFormat": "probe {{transport}} {{uplink}}",
          "refId": "A"
        },
        {
          "expr": "outline_ws_rust_uplink_health_effective{job=~\"$job\",instance=~\"$instance\",group=~\"$group\"}",
          "legendFormat": "effective {{transport}} {{uplink}}",
          "refId": "B"
        }
      ],
      "title": "Uplink Health: Probe vs Effective",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "description": "Active wire index per uplink/transport (0=primary, ≥1=fallback). A line stuck above 0 with no decay = sticky on fallback. pin_remaining shows the auto-failback timer; if it never reaches 0, downgrade is being re-extended.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"drawStyle": "line", "fillOpacity": 10, "lineWidth": 1, "showPoints": "auto"},
          "unit": "none"
        },
        "overrides": [
          {
            "matcher": {"id": "byRegexp", "options": "pin_remaining.*"},
            "properties": [
              {"id": "unit", "value": "s"},
              {"id": "custom.axisPlacement", "value": "right"}
            ]
          }
        ]
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 31},
      "id": 32,
      "options": {
        "legend": {"calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "targets": [
        {
          "expr": "outline_ws_rust_uplink_active_wire_index{job=~\"$job\",instance=~\"$instance\",group=~\"$group\"}",
          "legendFormat": "wire-idx {{transport}} {{uplink}}",
          "refId": "A"
        },
        {
          "expr": "outline_ws_rust_uplink_active_wire_pin_remaining_seconds{job=~\"$job\",instance=~\"$instance\",group=~\"$group\"}",
          "legendFormat": "pin_remaining {{transport}} {{uplink}}",
          "refId": "B"
        }
      ],
      "title": "Active Wire Index & Pin Remaining",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "description": "Failover events. A long quiet period followed by a manual switch (annotation) = the failure detector did NOT trigger, even though traffic was failing. That is the smoking gun for a stuck downgrade or a non-fatal hang the runtime missed.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"drawStyle": "bars", "fillOpacity": 80, "lineWidth": 1, "showPoints": "never"},
          "unit": "ops"
        }
      },
      "gridPos": {"h": 7, "w": 12, "x": 0, "y": 39},
      "id": 33,
      "options": {
        "legend": {"calcs": ["max", "sum"], "displayMode": "table", "placement": "bottom", "showLegend": true},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "targets": [
        {
          "expr": "sum by (transport, from_uplink, to_uplink) (rate(outline_ws_rust_uplink_failovers_total{job=~\"$job\",instance=~\"$instance\",group=~\"$group\"}[$__rate_interval]))",
          "legendFormat": "{{transport}} {{from_uplink}}→{{to_uplink}}",
          "refId": "A"
        }
      ],
      "title": "Failovers (rate)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "description": "Mid-session retries on Ack-Prefix path by outcome. failed_replay = server's up_acked offset fell outside our ring buffer; buffer_overflow = single chunk too big — both burn the retry budget without redial. These are exact cases where a session hangs forever instead of failing fast.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"drawStyle": "bars", "fillOpacity": 80, "lineWidth": 1, "showPoints": "never", "stacking": {"mode": "normal"}},
          "unit": "ops"
        }
      },
      "gridPos": {"h": 7, "w": 12, "x": 12, "y": 39},
      "id": 34,
      "options": {
        "legend": {"calcs": ["max", "sum"], "displayMode": "table", "placement": "bottom", "showLegend": true},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "targets": [
        {
          "expr": "sum by (transport, outcome) (rate(outline_ws_rust_uplink_mid_session_retries_total{job=~\"$job\",instance=~\"$instance\",group=~\"$group\"}[$__rate_interval]))",
          "legendFormat": "{{transport}} {{outcome}}",
          "refId": "A"
        }
      ],
      "title": "Mid-Session Retries (by outcome)",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 46},
      "id": 40,
      "panels": [],
      "title": "Failure Surface — what is breaking right before the hang",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "description": "Top runtime-failure causes by rate. Look for a cause that ramps just before a hang and stops only after the manual uplink switch.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"drawStyle": "line", "fillOpacity": 10, "lineWidth": 1, "showPoints": "never"},
          "unit": "ops"
        }
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 47},
      "id": 41,
      "options": {
        "legend": {"calcs": ["max", "sum"], "displayMode": "table", "placement": "bottom", "showLegend": true},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "targets": [
        {
