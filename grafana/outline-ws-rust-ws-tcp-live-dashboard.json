    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "unit": "short"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 1
      },
      "id": 1,
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "expr": "label_replace(sum by (instance) (outline_ws_rust_sessions_active{job=~\"$job\",instance=~\"$instance\",protocol=\"tcp\"}), \"instance_short\", \"$1\", \"instance\", \"^([^.]+).*\")",
          "legendFormat": "{{instance_short}} tcp sessions",
          "refId": "A"
        }
      ],
      "title": "Active TCP Sessions (shared)",
      "type": "timeseries"
    },
    {
